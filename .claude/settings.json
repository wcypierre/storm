{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/ci.sh\"",
            "shell": "bash",
            "asyncRewake": true,
            "timeout": 300,
            "statusMessage": "Running repo lint + tests"
          }
        ]
      }
    ]
  }
}
